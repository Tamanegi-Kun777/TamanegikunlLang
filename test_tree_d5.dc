class Tree {
  int depth;
  int size;
  int* leaves;
  int path[5];
}

int main(){
  Tree t;
  int i;
  int addr;
  int ok;

  t.depth = 5;
  t.size = 1 << t.depth;
  t.leaves = malloc(t.size * sizeof(int));

  for(i = 0; i < t.size; i = i + 1){
    t.leaves[i] = 0;
  }

  t.path[0] = 1;
  t.path[1] = 0;
  t.path[2] = 1;
  t.path[3] = 1;
  t.path[4] = 0;
  addr = 0;
  for(i = 0; i < t.depth; i = i + 1){
    addr = (addr << 1) | t.path[i];
  }
  t.leaves[addr] = 22;

  t.path[0] = 0;
  t.path[1] = 0;
  t.path[2] = 0;
  t.path[3] = 0;
  t.path[4] = 0;
  addr = 0;
  for(i = 0; i < t.depth; i = i + 1){
    addr = (addr << 1) | t.path[i];
  }
  t.leaves[addr] = 1;

  t.path[0] = 1;
  t.path[1] = 1;
  t.path[2] = 1;
  t.path[3] = 1;
  t.path[4] = 1;
  addr = 0;
  for(i = 0; i < t.depth; i = i + 1){
    addr = (addr << 1) | t.path[i];
  }
  t.leaves[addr] = 99;

  ok = 0;
  if(t.leaves[22] == 22){
    ok = ok + 1;
  }
  if(t.leaves[0] == 1){
    ok = ok + 1;
  }
  if(t.leaves[31] == 99){
    ok = ok + 1;
  }

  free(t.leaves);
  return ok;
}
