class Tree {
  int depth;
  int leaves[1024];
  int path[10];
}
int main(){
  Tree t;
  int i;
  int addr;

  t.depth = 3;
  t.path[0] = 1;
  t.path[1] = 0;
  t.path[2] = 1;

  addr = 0;
  for(i = 0; i < t.depth; i = i + 1){
    addr = (addr << 1) | t.path[i];
  }

  t.leaves[addr] = 42;
  return t.leaves[5];
}
